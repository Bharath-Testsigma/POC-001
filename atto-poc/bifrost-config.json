{
  "$schema": "https://www.getbifrost.ai/schema",
  "config_store": { "enabled": false },
  "logs_store":   { "enabled": false },
  "client": {
    "compat": {
      "should_drop_params": true
    }
  },
  "providers": {
    "openai": {
      "keys": [{ "name": "openai-key", "value": "env.OPENAI_API_KEY", "weight": 1, "models": ["*"] }]
    },
    "anthropic": {
      "keys": [{ "name": "anthropic-key", "value": "env.ANTHROPIC_API_KEY", "weight": 1, "models": ["*"] }]
    },
    "gemini": {
      "keys": [{ "name": "gemini-key", "value": "env.GOOGLE_API_KEY", "weight": 1, "models": ["*"] }]
    }
  }
}
