# ── LiteLLM Proxy (local) ─────────────────────────────────────────────────────
# These match the master_key in litellm_config.yaml — no need to change for local dev
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-atto-local

# ── Provider API keys ─────────────────────────────────────────────────────────
# Add keys only for the providers you want to use.
# Requests to models without a matching provider key will fail at the proxy.
GOOGLE_API_KEY=your_google_api_key_here        # Gemini Flash, Pro, 2.5 Flash
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Claude Haiku, Sonnet
OPENAI_API_KEY=your_openai_api_key_here        # GPT-4o, GPT-4o Mini

# ── App settings ──────────────────────────────────────────────────────────────
DEFAULT_MODEL=openai/gemini-flash
FALLBACK_MODEL=openai/claude-haiku
WORKSPACE_DIR=workspace
MAX_ITERATIONS=20
MAX_RETRIES=3
