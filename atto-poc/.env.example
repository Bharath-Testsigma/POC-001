# ── Bifrost Gateway (local) ───────────────────────────────────────────────────
BIFROST_URL=http://localhost:8080

# ── Provider API keys ─────────────────────────────────────────────────────────
# Add keys only for the providers you want to use.
# Bifrost reads these at startup from env vars (see bifrost-config.json).
GOOGLE_API_KEY=your_google_api_key_here        # Gemini Flash, Pro, 2.5 Flash
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Claude Haiku, Sonnet
OPENAI_API_KEY=your_openai_api_key_here        # GPT-4o, GPT-4o Mini

# ── App settings ──────────────────────────────────────────────────────────────
DEFAULT_MODEL=openai/gpt-4o-mini
FALLBACK_MODEL=anthropic/claude-haiku-4-5-20251001
WORKSPACE_DIR=workspace
MAX_ITERATIONS=20
MAX_RETRIES=3
