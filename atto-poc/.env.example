# ── Helicone OSS Gateway (local) ──────────────────────────────────────────────
# Helicone's self-hosted gateway is OpenAI-compatible and listens on /ai by default.
# If you do not enable gateway auth, the placeholder value below is sufficient.
HELICONE_GATEWAY_URL=http://localhost:8080/ai
HELICONE_API_KEY=placeholder-api-key

# ── Provider API keys ─────────────────────────────────────────────────────────
# The gateway routes by model prefix (google/*, anthropic/*, openai/*).
# Only fill in keys for providers you want to use.
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # models: anthropic/claude-*
GOOGLE_API_KEY=your_google_api_key_here         # models: google/gemini-*
OPENAI_API_KEY=your_openai_api_key_here         # models: openai/gpt-*, openai/o*

# ── App settings ──────────────────────────────────────────────────────────────
DEFAULT_MODEL=google/gemini-2.5-flash
FALLBACK_MODEL=openai/gpt-4o-mini
WORKSPACE_DIR=workspace
MAX_ITERATIONS=20
MAX_RETRIES=3
