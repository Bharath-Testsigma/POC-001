# ── Helicone OSS Gateway (local) ──────────────────────────────────────────────
# Helicone's self-hosted gateway is OpenAI-compatible and listens on /ai by default.
# If you do not enable gateway auth, the placeholder value below is sufficient.
HELICONE_GATEWAY_URL=http://localhost:8080/ai
HELICONE_API_KEY=placeholder-api-key

# ── Provider API keys ─────────────────────────────────────────────────────────
# Add keys only for the providers you want to route through Helicone.
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── App settings ──────────────────────────────────────────────────────────────
DEFAULT_MODEL=google/gemini-2.5-flash
FALLBACK_MODEL=openai/gpt-4o-mini
WORKSPACE_DIR=workspace
MAX_ITERATIONS=20
MAX_RETRIES=3
