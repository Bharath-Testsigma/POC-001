# Castari BYOK test configuration
# Replace placeholder values with your actual credentials before running.

ANTHROPIC_API_KEY=sk-ant-api03-.....
CASTARI_WORKER_URL=https://castari-worker.castari-proxy.workers.dev
OPENAI_API_KEY=sk-proj-.....
MODEL_NAME=or:z-ai/glm-4.6
OPENROUTER_API_KEY=sk-or-v1-.....

# Task tool subagents inherit the main model by default. Override to lock a tier.
CASTARI_SUBAGENT_MODEL=inherit # or model name

# Mode 2 — Portkey virtual-key routing
PORTKEY_API_KEY=pk-...
PORTKEY_VK_ANTHROPIC=vk-...
PORTKEY_VK_OPENAI=vk-...
PORTKEY_VK_GOOGLE=vk-...

# Internal demo route protection
# Leave as-is for localhost demos. Set DEMO_ROUTE_PROTECTION=off only if you intentionally
# need remote access to the internal demo API routes.
DEMO_ROUTE_PROTECTION=local-only
# Optional manual bypass token for trusted callers that need direct API access.
INTERNAL_ROUTE_TOKEN=
